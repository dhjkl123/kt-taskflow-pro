{
  "buildCommand": "npm install && cd src/client && npm install && npm run build",
  "outputDirectory": "src/client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
